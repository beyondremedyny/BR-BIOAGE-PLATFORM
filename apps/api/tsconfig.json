{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "../../",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": "../../",
    "paths": {
      "../../../../packages/shared/src": ["packages/shared/src/index.ts"],
      "../../../../packages/shared/src/*": ["packages/shared/src/*"]
    }
  },
  "include": [
    "src/**/*",
    "../../packages/shared/src/**/*"
  ]
}
