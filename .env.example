# Anthropic
ANTHROPIC_API_KEY=

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/br_bioage

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
VITE_CLERK_PUBLISHABLE_KEY=

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=beyond-remedy-labs

# Resend Email
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@beyondremedyny.com
CLINICIAN_NOTIFY_EMAIL=leon@beyondremedyny.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:5173
VITE_API_URL=http://localhost:3001
PORT=3001

# PDF (Puppeteer) — set PUPPETEER_EXECUTABLE_PATH on Railway/Linux if needed
SKIP_PDF_GENERATION=false
REQUIRE_PDF_ON_PUBLISH=false

# 90-day retest reminders (day 85)
ENABLE_RETEST_CRON=true
RETEST_CRON_SCHEDULE=0 9 * * *
RETEST_REMINDER_DAYS=85
RETEST_REMINDER_WINDOW=3
CRON_SECRET=

# Railway cron alternative: POST /api/cron/retest-reminders with header x-cron-secret
